# ---------- Core ----------
APP_NAME=Mood AI
JWT_SECRET=replace-with-a-long-random-string
DATABASE_URL=postgresql+asyncpg://mood:mood@localhost:5432/mood
REDIS_URL=redis://localhost:6379/0
# Vector store: with QDRANT_URL unset/localhost (default) memory/recall/doc-RAG run on
# pgvector INSIDE the DATABASE above — zero extra infra. Point it at a real Qdrant
# server (or set VECTOR_BACKEND=qdrant) to use Qdrant instead.
QDRANT_URL=http://localhost:6333
VECTOR_BACKEND=auto          # auto | pgvector | qdrant
EMBED_PROVIDER=auto          # auto | gemini | fastembed | openai — auto prefers Gemini when GEMINI_API_KEY is set
GEMINI_EMBED_MODEL=gemini-embedding-001
# Pause fact extraction + title prettifier (daily-budget shield for tiny LLM keys)
QUOTA_ECONOMY=false
CORS_ORIGINS=http://localhost:3000
UPLOAD_DIR=./storage

# ---------- xAI / Grok (REQUIRED) ----------
# Get a key at https://console.x.ai
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
MODEL_CHAT=grok-4
MODEL_FAST=grok-3-mini
MODEL_VISION=grok-2-vision-1212
MODEL_IMAGE=grok-2-image-1212
# Free FLUX stand-in while xAI image credits are at $0 (unset to return to xAI images)
IMAGE_FALLBACK_PROVIDER=pollinations
# Archive every generated image to durable storage (uses the R2_* creds below when set)
IMAGE_PERSIST=true
IMAGE_PERSIST_TTL_S=604800

# ---------- Brain cascade (optional extra tiers — zero code to add a provider) ----------
# 🥈 FreeTheAi extra capacity (free key from their Discord /signup)
FREETHEAI_API_KEY=
FREETHEAI_BASE_URL=https://api.freetheai.xyz/v1
FREETHEAI_MODEL=
FREETHEAI_MODEL_FAST=
# 🧬 Generic extra brain: Groq (console.groq.com), Cerebras, Mistral, OpenRouter (:free),
# or Cloudflare Workers AI (base https://api.cloudflare.com/client/v4/accounts/<id>/ai/v1)
EXTRA_BRAIN_API_KEY=
EXTRA_BRAIN_BASE_URL=https://api.groq.com/openai/v1
EXTRA_BRAIN_MODEL=
EXTRA_BRAIN_MODEL_FAST=

# ---------- Ops ----------
# 💓 keep the Neon compute hot (a SELECT 1 every 240s; false = allow idle suspension)
DB_KEEP_WARM=true
DB_KEEP_WARM_S=240

# ---------- Multi-provider router (optional; xAI is the default for everything) ----------
# Any OpenAI-compatible endpoint. Routing away from xAI needs BOTH the provider key
# AND a ROUTE_MODEL_* override, otherwise it safely falls back to xAI.
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# Claude path: point OPENAI_BASE_URL at an OpenAI-compat gateway (e.g. LiteLLM) & set PROVIDER_*=openai
PROVIDER_CHAT=xai
PROVIDER_CODING=xai
PROVIDER_AGENTS=xai
PROVIDER_DEEPSEARCH=xai
# ROUTE_MODEL_CODING=gemini-2.5-pro
# ROUTE_MODEL_AGENTS=gpt-4o
# ROUTE_MODEL_DEEPSEARCH=
# ROUTE_MODEL_CHAT=

# ---------- Web search ----------
# xai_live = built-in xAI Live Search (default, no extra key)
# tavily   = classic retrieval injected as context
SEARCH_PROVIDER=xai_live
TAVILY_API_KEY=

# ---------- Voice (Whisper STT + TTS) - optional, required for voice features ---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
WHISPER_MODEL=whisper-1
TTS_MODEL=tts-1
TTS_VOICE=alloy

# ---------- Stripe subscriptions (optional) ----------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# ---------- Custom domains (connect own + real-time purchase) ----------
# Platform DNS: users CNAME their custom domains to this host (your edge proxy domain)
PLATFORM_CNAME_TARGET=
# Apex IP for purchased domains (auto-configured after checkout; optional)
PLATFORM_A_RECORD_IP=
# Your margin on top of registrar cost price (%)
DOMAIN_MARKUP_PCT=20
# Registrar API (developer.godaddy.com/keys). "ote" = sandbox (test the full
# purchase flow for free) → "production" = real registrations & charges.
GODADDY_API_KEY=
GODADDY_API_SECRET=
GODADDY_ENV=ote
# Optional: auto-attach verified/purchased domains to your Vercel project
VERCEL_API_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=
# Edge proxy (docker compose --profile edge): platform base domain + cert contact
BASE_DOMAIN=localhost
ACME_EMAIL=ops@example.com
# How often the background watchdog refreshes registrar expiry dates (hours)
DOMAIN_SYNC_HOURS=24
# "Renew now" button + owner reminder email appear inside this window (days)
DOMAIN_RENEW_WINDOW_DAYS=30
# Workspace invite link lifetime (days)
INVITE_TTL_DAYS=7

# ---------- Limits ----------
MAX_UPLOAD_MB=25
MAX_FILE_CHARS=30000
CHAT_RATE_LIMIT_PER_MIN=30
MEMORY_TOP_K=6
# Cross-conversation recall (Mood remembers previous chats)
RECALL_TOP_K=3
RECALL_MIN_SCORE=0.38
RECENT_CHATS_DIGEST=2

# ---------- Plugins (Gmail / Google Calendar / GitHub via OAuth) ----------
# Public URL of THIS backend (OAuth callbacks land here)
BACKEND_PUBLIC_URL=http://localhost:8000
# Encryption key for stored OAuth tokens — generate:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PLUGIN_TOKEN_KEY=
PLUGIN_MAX_CALLS=4
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ---------- Video generation ----------
VIDEO_PROVIDER=xai
MODEL_VIDEO=grok-video-1
VIDEO_MAX_WAIT_SECONDS=240

# ---------- Code sandbox (built-in run_python_code tool) ----------
# NOT a hardened boundary — subprocess in the backend container with rlimits + timeout.
SANDBOX_ENABLED=true
SANDBOX_TIMEOUT=8
SANDBOX_MAX_OUTPUT=6000

# ---------- ⚔️ Arena (Pro feature) ----------
# Panel models per provider — a provider only joins the arena if its API key is set.
ARENA_XAI_MODEL=            # empty → MODEL_CHAT (grok-4), also the judge
ARENA_OPENAI_MODEL=gpt-4o
ARENA_GEMINI_MODEL=gemini-2.5-pro
ARENA_CODE_MODEL=grok-code-fast-1

# ---------- 🛡 Owner / admin (see docs/ARCHITECTURE.md § owner panel) ----------
# Emails that are always admin (comma separated), in addition to users.is_admin.
ADMIN_EMAILS=
# Guaranteed owner login, created (or promoted) automatically at backend boot:
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_PASSWORD=
# Optional: seed a sign-up access code ("app password") — new registrations must
# supply it. Rotatable later from the owner panel (stored hashed in the DB).
APP_PASSWORD=

# ---------- Media analysis uploads ----------
MAX_AUDIO_UPLOAD_MB=15
MAX_VIDEO_UPLOAD_MB=50
VIDEO_ANALYSIS_FRAMES=6

# ---------- Ops / observability ----------
# create tables automatically (dev). In production set false and run `alembic upgrade head`.
AUTO_CREATE_TABLES=true
# OpenTelemetry tracing (optional): http://<jaeger-or-collector>:4318
OTEL_EXPORTER_OTLP_ENDPOINT=
